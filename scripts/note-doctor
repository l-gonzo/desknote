#!/usr/bin/env bash
set -u
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

ok() { printf '\033[32m[OK]\033[0m %s\n' "$*"; }
warn() { printf '\033[33m[AVISO]\033[0m %s\n' "$*"; }
fail() { printf '\033[31m[FALTA]\033[0m %s\n' "$*"; }

printf 'Note Desktop doctor %s\n\n' "0.2.0"
critical=(labwc Xwayland cage gtkgreet note-shell note-settings wlrctl swaybg mako wpctl)
for command in "${critical[@]}"; do
  if command -v "$command" >/dev/null 2>&1; then ok "$command: $(command -v "$command")"; else fail "$command"; fi
done
if [[ -x /usr/sbin/greetd ]]; then
  ok "greetd: /usr/sbin/greetd"
elif [[ -x /usr/bin/greetd ]]; then
  ok "greetd: /usr/bin/greetd"
elif command -v greetd >/dev/null 2>&1; then
  ok "greetd: $(command -v greetd)"
else
  fail "greetd"
fi

printf '\nSesión:\n'
printf '  XDG_SESSION_TYPE=%s\n' "${XDG_SESSION_TYPE:-sin definir}"
printf '  XDG_CURRENT_DESKTOP=%s\n' "${XDG_CURRENT_DESKTOP:-sin definir}"
printf '  WAYLAND_DISPLAY=%s\n' "${WAYLAND_DISPLAY:-sin definir}"
printf '  DISPLAY=%s\n' "${DISPLAY:-sin definir}"

printf '\nGráficos:\n'
lspci -nnk 2>/dev/null | grep -EA3 'VGA|3D|Display' || true
if command -v vulkaninfo >/dev/null 2>&1; then
  vulkaninfo --summary 2>/dev/null | sed -n '1,35p' || warn 'Vulkan no respondió'
fi

for group in video render input; do
  if id -nG "$USER" | tr ' ' '\n' | grep -qx "$group"; then ok "Usuario en grupo $group"; else warn "Usuario fuera de $group"; fi
done

if systemctl is-enabled greetd >/dev/null 2>&1; then ok 'greetd habilitado'; else warn 'greetd no está habilitado'; fi
if systemctl is-active greetd >/dev/null 2>&1; then ok 'greetd activo'; else warn 'greetd no está activo'; fi

if [[ ${XDG_SESSION_TYPE:-} == wayland ]]; then ok 'Sesión Wayland'; else warn 'No estás dentro de una sesión Wayland'; fi

printf '\nEn caso de pantalla negra:\n'
printf '  Ctrl+Alt+F2\n  sudo systemctl disable --now greetd\n  sudo systemctl set-default multi-user.target\n'
