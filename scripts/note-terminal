#!/bin/sh
set -u
if [ "${1:-}" = "-e" ]; then
  shift
  if command -v foot >/dev/null 2>&1; then exec foot -e "$@"; fi
  if command -v kgx >/dev/null 2>&1; then exec kgx -- "$@"; fi
  if command -v gnome-terminal >/dev/null 2>&1; then exec gnome-terminal -- "$@"; fi
  exec xterm -e "$@"
fi
if command -v foot >/dev/null 2>&1; then exec foot; fi
if command -v kgx >/dev/null 2>&1; then exec kgx; fi
if command -v gnome-terminal >/dev/null 2>&1; then exec gnome-terminal; fi
exec xterm
