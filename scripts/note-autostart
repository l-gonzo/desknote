#!/bin/sh
set -u

pkill -x swaybg 2>/dev/null || true
swaybg -i /usr/share/note-desktop/wallpapers/note-wave.svg -m fill >/dev/null 2>&1 &

systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE 2>/dev/null || true
systemctl --user --no-block start graphical-session.target note-session.target 2>/dev/null || {
  # Emergency fallback when the user systemd instance is unavailable.
  mako >/dev/null 2>&1 &
  lxpolkit >/dev/null 2>&1 &
  note-shell >/dev/null 2>&1 &
}
