# Copia este archivo a /etc/note-desktop/gpu.conf o
# ~/.config/note-desktop/gpu.conf y descomenta sólo lo necesario.

# Renderizado por software para VMs problemáticas:
# export WLR_RENDERER=pixman
# export WLR_NO_HARDWARE_CURSORS=1

# Orden manual para equipos multi-GPU:
# export WLR_DRM_DEVICES=/dev/dri/card1:/dev/dri/card0
