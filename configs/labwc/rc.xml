<?xml version="1.0"?>
<labwc_config xmlns="http://openbox.org/3.4/rc">
  <core>
    <decoration>server</decoration>
    <gap>10</gap>
    <adaptiveSync>yes</adaptiveSync>
    <reuseOutputMode>yes</reuseOutputMode>
    <xwaylandPersistence>no</xwaylandPersistence>
  </core>

  <theme>
    <name>Note</name>
    <icon>Adwaita</icon>
    <cornerRadius>12</cornerRadius>
    <titlebar><layout>close,max,iconify:</layout></titlebar>
    <font place="ActiveWindow"><name>Inter</name><size>10</size><weight>Semibold</weight></font>
    <font place="InactiveWindow"><name>Inter</name><size>10</size></font>
    <font place="MenuItem"><name>Inter</name><size>10</size></font>
    <font place="OnScreenDisplay"><name>Inter</name><size>11</size><weight>Bold</weight></font>
  </theme>

  <desktops number="4">
    <popupTime>650</popupTime>
    <prefix>Escritorio</prefix>
  </desktops>

  <resize><popupShow>Always</popupShow><drawContents>yes</drawContents></resize>
  <focus><followMouse>no</followMouse><raiseOnFocus>no</raiseOnFocus></focus>
  <snapping>
    <screenEdgeStrength>18</screenEdgeStrength>
    <windowEdgeStrength>10</windowEdgeStrength>
  </snapping>

  <keyboard>
    <default />
    <keybind key="Super_L" onRelease="yes"><action name="Execute" command="note-overview" /></keybind>
    <keybind key="W-Space"><action name="Execute" command="note-overview" /></keybind>
    <keybind key="W-Return"><action name="Execute" command="note-terminal" /></keybind>
    <keybind key="W-e"><action name="Execute" command="note-files" /></keybind>
    <keybind key="W-b"><action name="Execute" command="note-browser" /></keybind>
    <keybind key="W-comma"><action name="Execute" command="note-settings" /></keybind>
    <keybind key="W-l"><action name="Execute" command="note-lock" /></keybind>
    <keybind key="W-q"><action name="Close" /></keybind>
    <keybind key="W-f"><action name="ToggleFullscreen" /></keybind>
    <keybind key="W-m"><action name="Iconify" /></keybind>
    <keybind key="W-Up"><action name="ToggleMaximize" /></keybind>
    <keybind key="W-Left"><action name="SnapToEdge" direction="left" /></keybind>
    <keybind key="W-Right"><action name="SnapToEdge" direction="right" /></keybind>
    <keybind key="W-Down"><action name="SnapToEdge" direction="down" /></keybind>
    <keybind key="W-C-Left"><action name="GoToDesktop" to="left" wrap="yes" /></keybind>
    <keybind key="W-C-Right"><action name="GoToDesktop" to="right" wrap="yes" /></keybind>
    <keybind key="W-C-S-Left"><action name="SendToDesktop" to="left" wrap="yes" follow="yes" /></keybind>
    <keybind key="W-C-S-Right"><action name="SendToDesktop" to="right" wrap="yes" follow="yes" /></keybind>
    <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
    <keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind>
    <keybind key="W-6"><action name="GoToDesktop" to="6" /></keybind>
    <keybind key="W-7"><action name="GoToDesktop" to="7" /></keybind>
    <keybind key="W-8"><action name="GoToDesktop" to="8" /></keybind>
    <keybind key="W-9"><action name="GoToDesktop" to="9" /></keybind>
    <keybind key="Print"><action name="Execute" command="note-screenshot" /></keybind>
    <keybind key="XF86AudioRaiseVolume"><action name="Execute" command="wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+" /></keybind>
    <keybind key="XF86AudioLowerVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" /></keybind>
    <keybind key="XF86AudioMute"><action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" /></keybind>
    <keybind key="XF86AudioPlay"><action name="Execute" command="playerctl play-pause" /></keybind>
    <keybind key="XF86AudioNext"><action name="Execute" command="playerctl next" /></keybind>
    <keybind key="XF86AudioPrev"><action name="Execute" command="playerctl previous" /></keybind>
    <keybind key="XF86MonBrightnessUp"><action name="Execute" command="brightnessctl set +5%" /></keybind>
    <keybind key="XF86MonBrightnessDown"><action name="Execute" command="brightnessctl set 5%-" /></keybind>
  </keyboard>

  <mouse>
    <default />
    <context name="Root">
      <mousebind button="Right" action="Press"><action name="ShowMenu" menu="root-menu" /></mousebind>
      <mousebind direction="Up" action="Scroll"><action name="GoToDesktop" to="left" wrap="yes" /></mousebind>
      <mousebind direction="Down" action="Scroll"><action name="GoToDesktop" to="right" wrap="yes" /></mousebind>
    </context>
  </mouse>

  <libinput>
    <device category="default">
      <naturalScroll>no</naturalScroll>
      <pointerSpeed>0.0</pointerSpeed>
      <tap>yes</tap>
      <tapButtonMap>lrm</tapButtonMap>
      <disableWhileTyping>yes</disableWhileTyping>
    </device>
    <device category="touchpad">
      <naturalScroll>yes</naturalScroll>
      <clickMethod>clickfinger</clickMethod>
      <middleEmulation>yes</middleEmulation>
    </device>
  </libinput>
</labwc_config>
